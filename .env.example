# Application
APP_NAME=x9core
APP_ENV=development
DEBUG=true
API_PORT=8000

# Database
POSTGRES_USER=x9core
POSTGRES_PASSWORD=x9core
POSTGRES_DB=x9core
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://x9core:x9core@postgres:5432/x9core

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Scraper (Step 4+)
SCRAPER_HEADLESS=true
SCRAPER_PROXY_URL=
SCRAPER_REQUEST_DELAY_SECONDS=2
